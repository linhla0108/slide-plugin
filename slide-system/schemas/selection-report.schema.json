{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sun.studio/slide-system/selection-report.schema.json",
  "title": "Visual Selection Report",
  "type": "object",
  "required": ["request_id", "generated_at", "decision", "candidates"],
  "properties": {
    "request_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "generated_by": { "type": "string" },
    "scorer_version": { "type": "string" },
    "retrieval_index": { "type": ["string", "null"] },
    "rejected_items": { "type": "array", "items": { "type": "string" } },
    "decision": {
      "type": "object",
      "required": ["action", "item_id", "score", "reason", "extraction_recommended"],
      "properties": {
        "action": { "enum": ["reuse", "text-only"] },
        "item_id": { "type": ["string", "null"] },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "reason": { "type": "string" },
        "extraction_recommended": { "type": "boolean" },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "evidence": {
          "type": "object",
          "properties": {
            "scored_intent_terms": { "type": "array", "items": { "type": "string" } },
            "dropped_intent_terms": { "type": "array", "items": { "type": "string" } },
            "subject_warnings": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "reuse" } } },
          "then": { "properties": { "item_id": { "type": "string" } } }
        },
        {
          "if": { "properties": { "action": { "const": "text-only" } } },
          "then": {
            "properties": {
              "item_id": { "type": "null" },
              "score": { "const": 0 }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "eligible", "score", "criteria", "reasons"],
        "properties": {
          "item_id": { "type": "string" },
          "eligible": { "type": "boolean" },
          "score": { "type": "number" },
          "criteria": { "type": "object" },
          "reasons": { "type": "array", "items": { "type": "string" } },
          "retrieval": { "type": "object" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

