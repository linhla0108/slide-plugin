{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sun.studio/slide-system/slot-content-plan.schema.json",
  "title": "Job-local Slot Content Plan",
  "type": "object",
  "required": ["schema_version", "slides"],
  "properties": {
    "schema_version": {"const": 1},
    "slides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["request_id", "item_id", "slots"],
        "properties": {
          "request_id": {"type": "string", "minLength": 1},
          "item_id": {"type": "string", "minLength": 1},
          "slots": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["slot_id", "display_copy"],
              "properties": {
                "slot_id": {"type": "string", "minLength": 1},
                "display_copy": {"type": "string", "minLength": 1},
                "speaker_notes": {"type": "string"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
